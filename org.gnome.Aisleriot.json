{
    "app-id": "org.gnome.Aisleriot",
    "runtime": "org.gnome.Platform",
    "runtime-version": "48",
    "sdk": "org.gnome.Sdk",
    "command": "sol",
    "rename-appdata-file": "sol.metainfo.xml",
    "rename-desktop-file": "sol.desktop",
    "rename-icon": "gnome-aisleriot",
    "copy-icon": true,
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri",
        "--socket=pulseaudio"
    ],
    "cleanup": [
        "/include",
        "/lib/pkgconfig",
        "/share/pkgconfig",
        "/share/aclocal",
        "/man",
        "/share/man",
        "/share/gtk-doc",
        "*.la",
        "*.a"
    ],
    "modules": [
        {
            "name": "guile",
            "cleanup": [
                "/bin",
                "/lib/libguile-3.0.so.1.2.0-gdb.scm"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://ftp.gnu.org/gnu/guile/guile-3.0.10.tar.xz",
                    "sha256": "bd7168517fd526333446d4f7ab816527925634094fbd37322e17e2b8d8e76388",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 1277,
                        "url-template": "https://ftp.gnu.org/gnu/guile/guile-$version.tar.xz"
                    }
                }
            ],
            "modules": [
                {
                    "name": "gc",
                    "cleanup": [
                        "/share"
                    ],
                    "sources": [
                        {
                            "type": "archive",
                            "url": "https://www.hboehm.info/gc/gc_source/gc-8.2.8.tar.gz",
                            "sha256": "7649020621cb26325e1fb5c8742590d92fb48ce5c259b502faf7d9fb5dabb160",
                            "x-checker-data": {
                                "type": "anitya",
                                "project-id": 876,
                                "url-template": "https://www.hboehm.info/gc/gc_source/gc-$version.tar.gz"
                            }
                        }
                    ],
                    "modules": [
                        {
                            "name": "libatomic_ops",
                            "sources": [
                                {
                                    "type": "archive",
                                    "url": "https://github.com/ivmai/libatomic_ops/archive/refs/tags/v7.8.2.tar.gz",
                                    "sha256": "ad8428a40e01d41bc4ddad3166afa1fc175c9e58d8ef7ddbd7ef3298e32ac37b",
                                    "x-checker-data": {
                                        "type": "anitya",
                                        "project-id": 1561,
                                        "url-template": "https://github.com/ivmai/libatomic_ops/archive/refs/tags/v$version.tar.gz"
                                    }
                                }
                            ]
                        }
                    ]
                }
            ]
        },
        "shared-modules/libcanberra/libcanberra.json",
        {
            "name": "aisleriot",
            "buildsystem": "meson",
            "config-opts": [
                "-Dtheme_kde=false",
                "-Dgconf=false"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.gnome.org/sources/aisleriot/3.22/aisleriot-3.22.35.tar.xz",
                    "tag": "3.22.35",
                    "sha256": "01e604cd7009a36c0c5f15424a904e46f8362c306ba5f6bc71fac8a5e7463bf0",
                    "x-checker-data": {
                        "type": "gnome",
                        "is-important": true,
                        "name": "aisleriot"
                    }
                },
                {
                    "type": "patch",
                    "paths": [
                        "appdata.patch",
                        "aisleriot-meson.patch"
                    ]
                }
            ]
        }
    ]
}
