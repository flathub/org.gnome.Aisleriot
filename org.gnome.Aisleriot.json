{
    "app-id": "org.gnome.Aisleriot",
    "runtime": "org.gnome.Platform",
    "runtime-version": "49",
    "sdk": "org.gnome.Sdk",
    "command": "sol",
    "rename-appdata-file": "sol.metainfo.xml",
    "rename-desktop-file": "sol.desktop",
    "rename-icon": "gnome-aisleriot",
    "copy-icon": true,
    "finish-args": [
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--device=dri",
        "--socket=pulseaudio"
    ],
    "cleanup": [
        "/include",
        "/lib/pkgconfig",
        "/share/pkgconfig",
        "/share/aclocal",
        "/man",
        "/share/man",
        "/share/gtk-doc",
        "*.la",
        "*.a"
    ],
    "modules": [
        {
            "name": "guile",
            "build-options": {
                "cflags": "-std=gnu17"
            },
            "cleanup": [
                "/bin",
                "/lib/libguile-3.0.so.1.2.0-gdb.scm"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://ftp.gnu.org/gnu/guile/guile-3.0.10.tar.xz",
                    "sha256": "bd7168517fd526333446d4f7ab816527925634094fbd37322e17e2b8d8e76388"
                }
            ],
            "modules":[
                {
                    "name": "gc",
                    "cleanup": [
                        "/share"
                    ],
                    "sources": [
                        {
                            "type": "archive",
                            "url": "https://github.com/bdwgc/bdwgc/releases/download/v8.2.10/gc-8.2.10.tar.gz",
                            "sha256": "832cf4f7cf676b59582ed3b1bbd90a8d0e0ddbc3b11cb3b2096c5177ce39cc47"
                        }
                    ],
                    "modules": [
                        {
                            "name": "libatomic_ops",
                            "sources": [
                                {
                                    "type": "archive",
                                    "url": "https://github.com/bdwgc/libatomic_ops/releases/download/v7.8.4/libatomic_ops-7.8.4.tar.gz",
                                    "sha256": "2356e002e80ef695875e971d6a4fd8c61ca5c6fa4fd1bf31cce54a269c8bfcd5"
                                }
                            ]
                        }
                    ]
                }
            ]
        },
        "shared-modules/libcanberra/libcanberra.json",
        {
            "name": "aisleriot",
            "buildsystem": "meson",
            "config-opts": [
                "-Dtheme_kde=false",
                "-Dgconf=false"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.gnome.org/sources/aisleriot/3.22/aisleriot-3.22.35.tar.xz",
                    "tag": "3.22.35",
                    "sha256": "01e604cd7009a36c0c5f15424a904e46f8362c306ba5f6bc71fac8a5e7463bf0",
                    "x-checker-data": {
                        "type": "gnome",
                        "is-important": true,
                        "name": "aisleriot"
                    }
                },
                {
                    "type": "patch",
                    "paths": [
                        "appdata.patch",
                        "aisleriot-meson.patch"
                    ]
                }
            ]
        }
    ]
}
